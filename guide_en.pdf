<h1 class="chapter" id="ch11">Chapter 11: Room Placement Guide</h1>
<h2 class="section" id="room-chart">Room Placement Master Chart</h2>
<table>
  <tr><th>Room Type</th><th>Best Zone</th><th>Acceptable</th><th>Avoid</th></tr>
  <tr class="good-row"><td>Master Bedroom</td><td>SW (9,10,11)</td><td>S, NW</td><td>NE, SE, Centre</td></tr>
  <tr><td>Bedroom 2</td><td>S, NNW (12-15)</td><td>W, NW</td><td>NE, SE</td></tr>
  <tr class="good-row"><td>Kitchen</td><td>SE (5,6,7)</td><td>NW</td><td>NE, SW, Centre</td></tr>
  <tr class="good-row"><td>Puja Room</td><td>NE (1,2,3,4)</td><td>E, N</td><td>S, SW, SE, W</td></tr>
